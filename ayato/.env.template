#-- Base Configuration for Ayato --#
AYATO_DEBUG=false
AYATO_PORT=8080
AYATO_MAX_SIZE=1000000
AYATO_MAX_BATCH_PACKAGES=16
AYATO_MAX_BATCH_BYTES=2147483648

#-- User Authorization Configuration for Ayato --#
# Browser users authenticate with GitHub OAuth. CLI users receive a short-lived
# Bearer token plus a rotating refresh token from the same flow.
AYATO_AUTH_GITHUB_CLIENT_ID=
AYATO_AUTH_GITHUB_CLIENT_SECRET=
AYATO_AUTH_PUBLIC_ORIGIN=https://repo.example.com
AYATO_AUTH_SESSION_SECRET=replace-with-at-least-32-random-bytes
AYATO_AUTH_BOOTSTRAP_ADMIN_GITHUB_ID=
AYATO_AUTH_TRUSTED_PROXIES=127.0.0.1/32

# Service credentials are JSON because every key is named and scoped. This
# example lets a Miko worker publish only to "aur" and register its signer cert.
AYATO_AUTH_CI_API_KEYS=[{"name":"miko-worker","key":"replace-with-256-bit-key","publish_repos":["aur"],"scopes":["signer:register"]}]

#-- Database Store Configuration for Ayato --#
# badgerdb, sql, or cfkv. CLI/OAuth refresh requires an atomic store, so use
# badgerdb or sql when AYATO_AUTH_SESSION_SECRET is configured; cfkv fails fast.
AYATO_STORE_DBTYPE=

# SQL
AYATO_STORE_SQL_DRIVER=
AYATO_STORE_SQL_HOST=
AYATO_STORE_SQL_PORT=
AYATO_STORE_SQL_USER=
AYATO_STORE_SQL_PASSWORD=
AYATO_STORE_SQL_DATABASE=
AYATO_STORE_SQL_ADDITIONALDSN=

# Cloudflare KV
AYATO_STORE_CFKV_NAMESPACE=
AYATO_STORE_CFKV_ACCOUNTID=
AYATO_STORE_CFKV_TOKEN=

# BadgerDB
AYATO_STORE_BADGERDB=

#-- Binary Store Configuration for Ayato --#
# s3 or localfs
AYATO_STORE_STORAGETYPE=

AYATO_STORE_LOCALREPODIR=

AYATO_STORE_AWSS3_REGION=
AYATO_STORE_AWSS3_BUCKET=
AYATO_STORE_AWSS3_ACCESSKEYID=
AYATO_STORE_AWSS3_SECRETKEY=
AYATO_STORE_AWSS3_ENDPOINT=
