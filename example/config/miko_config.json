{
  "debug": true,
  "port": 8081,
  "builder": {
    "backend": "container",
    "timeout": "30m",
    "docker": {
      "image": "archlinux:latest"
    }
  },
  "concurrency": 2,
  "max_size": 1000000000,
  "signing": {
    "mode": "disabled"
  },
  "build": {
    "gnupg_home": "",
    "resolve_aur_deps": false,
    "aur_rpc_url": ""
  },
  "auth": {
    "api_keys": [
      { "name": "ayato-proxy", "key": "example-build-key", "scopes": ["build:admin"] }
    ]
  },
  "ayato": {
    "url": "http://ayato:8080",
    "api_key": "example-ci-key"
  },
  "data_dir": "/data/jobs"
}
