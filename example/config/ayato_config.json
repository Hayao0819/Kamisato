{
  "debug": true,
  "port": 8080,
  "max_size": 1000000000,
  "auth": {
    "username": "ayato",
    "password": "password",
    "trusted_proxies": ["172.16.0.0/12"],
    "ci": {
      "api_keys": [
        { "name": "myrepo-ci", "key": "example-ci-key", "publish_repos": ["myrepo"] }
      ],
      "github_oidc": {
        "enabled": false,
        "audience": "https://repo.example.com",
        "publishers": [
          {
            "repository": "FascodeNet/alterlinux-repo",
            "allow_refs": ["refs/heads/main"],
            "publish_repos": ["myrepo"]
          }
        ]
      }
    }
  },
  "store": {
    "db_type": "badgerdb",
    "badgerdb": "/data/db",
    "storage_type": "localfs",
    "local_repo_dir": "/data/repo"
  },
  "miko": {
    "url": "http://miko:8081",
    "api_key": "example-build-key"
  },
  "aur": {
    "enabled": true,
    "maintainer": "myrepo-team",
    "upstream": {
      "enabled": true
    }
  },
  "repos": [
    {
      "name": "myrepo",
      "arches": ["x86_64"]
    }
  ]
}
