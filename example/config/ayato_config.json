{
  "debug": true,
  "port": 8080,
  "max_size": 1000000000,
  "max_batch_packages": 16,
  "max_batch_bytes": 2147483648,
  "auth": {
    "github": {
      "client_id": "github-oauth-client-id",
      "client_secret": "github-oauth-client-secret"
    },
    "public_origin": "https://repo.example.com",
    "session_secret": ["replace-with-at-least-32-random-bytes"],
    "bootstrap_admin_github_id": 123456,
    "trusted_proxies": ["172.16.0.0/12"],
    "ci": {
      "api_keys": [
        { "name": "miko-worker", "key": "example-ci-key", "publish_repos": ["myrepo"], "scopes": ["signer:register"] }
      ],
      "github_oidc": {
        "enabled": false,
        "audience": "https://repo.example.com",
        "publishers": [
          {
            "repository": "FascodeNet/alterlinux-repo",
            "allow_refs": ["refs/heads/main"],
            "publish_repos": ["myrepo"]
          }
        ]
      }
    }
  },
  "store": {
    "db_type": "badgerdb",
    "badgerdb": "/data/db",
    "storage_type": "localfs",
    "local_repo_dir": "/data/repo"
  },
  "miko": {
    "url": "http://miko:8081",
    "api_key": "example-build-key"
  },
  "aur": {
    "enabled": true,
    "maintainer": "myrepo-team",
    "upstream": {
      "enabled": true
    }
  },
  "repos": [
    {
      "name": "myrepo",
      "arches": ["x86_64"]
    }
  ]
}
